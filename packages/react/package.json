      "types": "./src/components/agent-graph/index.ts",
      "import": "./src/components/agent-graph/index.ts"
    },
    "./types": {
      "types": "./src/core/agent-graph/types.ts",
      "import": "./src/core/agent-graph/types.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
